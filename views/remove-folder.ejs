<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% if (locals.user) { %>
        <h3>Remove folder</h3>
        <form action="/remove-folder" method="POST">
            <div class="form-group">
                <label for="deleteFolder">Name of folder to delete: </label>
                <input type="text" id="deleteFolder" name="deleteFolder">
            </div>
            <button type="submit">Submit</button>
    <% } %>
</body>
</html>